// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
  schemas  = ["public", "auth"]
}

model User {
  id           String   @id @default(uuid())
  username     String?  @unique
  email        String   @unique
  name         String
  surname      String?
  passwordHash String   @map("password_hash")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @map("updated_at")

  @@schema("auth")
}

model Gasto {
  id            String    @id @default(uuid())
  nombre        String
  tipo          TipoGasto @default(Fijo)
  cuotasTotal   Int       @default(0) @map("cuotas_total")
  cuotasPagadas Int       @default(0) @map("cuotas_pagadas")
  montoArs      Decimal   @default(0) @map("monto_ars")
  montoUsd      Decimal   @default(0) @map("monto_usd")
  fechaInicio   DateTime  @map("fecha_inicio")
  tarjetas      Tarjeta[]
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @map("updated_at")

  @@schema("public")
}

model Ingreso {
  id          String   @id @default(uuid())
  descripcion String
  montoArs    Decimal  @default(0) @map("monto_ars")
  montoUsd    Decimal  @default(0) @map("monto_usd")
  moneda      Currency @default(ARS)
  periodo     DateTime
  tipoCambio  Decimal  @map("tipo_cambio")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @map("updated_at")

  @@schema("public")
}

model Tarjeta {
  id               String   @id @default(uuid())
  nombre           String
  limiteUsd        Decimal  @map("limite_usd")
  fechaCierre      DateTime @map("fecha_cierre")
  fechaVencimiento DateTime @map("fecha_vencimiento")
  gasto            Gasto    @relation(fields: [gastoId], references: [id])
  gastoId          String   @map("gasto_id")
  esNoTarjeta      Boolean  @map("es_no_tarjeta")
  createdAt        DateTime @default(now()) @map("created_at")
  updatedAt        DateTime @map("updated_at")

  @@schema("public")
}

model PeriodoMensual {
  id         String   @id @default(uuid())
  anio       Int
  mes        Int
  tipoCambio Decimal  @map("tipo_cambio")
  cerradoEn  DateTime @map("cerrado_en")
  activo     Boolean
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @map("updated_at")

  @@schema("public")
}

model DeudaExtra {
  id            String      @id @default(uuid())
  descripcion   String
  monto         Decimal
  moneda        Currency    @default(ARS)
  observaciones String
  estado        EstadoDeuda
  createdAt     DateTime    @default(now()) @map("created_at")
  updatedAt     DateTime    @map("updated_at")

  @@schema("public")
}

enum EstadoDeuda {
  Activa
  Saldada

  @@schema("public")
}

enum TipoGasto {
  Fijo
  Cuotas

  @@schema("public")
}

enum Currency {
  ARS
  USD

  @@schema("public")
}
