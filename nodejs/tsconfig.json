{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "esModuleInterop": true,
    "strict": true,
    "skipLibCheck": true,
    "outDir": "dist",
    "rootDir": "."
  },
  "include": ["app.ts", "lib/**/*.ts", "shared/**/*.ts", "src/controllers/**/*.ts"],
  "exclude": ["node_modules", "src/generated"]
}
